# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
# Get your BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# OPTION 1: Use Neon Connection URL (Recommended for Neon)
# Get this from your Neon dashboard and paste it directly
DATABASE_URL=postgresql://user:password@ep-shy-meadow-69142621-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# OPTION 2: Use Individual Parameters (for local PostgreSQL or other providers)
# Uncomment and fill these if not using DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_database_password
# DB_NAME=budget_app
# DB_SSLMODE=prefer

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Temporary PDF filename for processing (default: temp_uploaded_statement.pdf)
TEMP_PDF_FILENAME=temp_uploaded_statement.pdf

# Debug mode: true or false (default: false)
DEBUG_MODE=false

# ============================================================================
# PDF PARSING CONFIGURATION
# ============================================================================
# Regex pattern for extracting transactions from maib bank statements
# Format: (date) (shop_name) (amount_in_mdl)
PDF_PATTERN=(\d{4}-\d{2}-\d{2})\s+(?:\d{4}-\d{2}-\d{2})\s+(.+?)\s+(-\d[\d\s.,]*\.\d{2})\s+MDL

# Keywords to filter out (P2P transfers)
FILTER_P2P=P2P de iesire

# Keywords to filter out (A2A transfers)
FILTER_A2A=A2A de intrare
